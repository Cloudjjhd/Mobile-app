<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mobile_app.Pages.ReminderSettingsPage"
             Title="Reminder Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Reminder Settings"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Reminder Type:" />
            <Label Text="( ) No Reminder" />
            <Label Text="( ) 10 minutes before" />
            <Label Text="(✓) 30 minutes before" />
            <Label Text="Repeat: Once" />
            <Label Text="Sound: Default" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>